[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.7
reloadable = true

[libraries]
linux.debug.x86_64 =     "res://addons/m_timer/bin/linux_64/debug/libm_timer.so"
linux.release.x86_64 =     "res://addons/m_timer/bin/linux_64/release/libm_timer.so"
windows.debug.x86_64 =     "res://addons/m_timer/bin/windows_64/debug/libm_timer.dll"
windows.release.x86_64 =     "res://addons/m_timer/bin/windows_64/release/libm_timer.dll"

[icons]
MTimer = "res://addons/m_timer/icons/hourglass.svg"
